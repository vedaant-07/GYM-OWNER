# SE7EN FIT Gym Owner Website
# Render / local frontend configuration

# Shared production backend API. Do not put the Supabase project URL here.
VITE_API_BASE_URL=https://se7en-fit-api.onrender.com/api
VITE_API_TIMEOUT_MS=15000

# Supabase public frontend values, only when a screen directly needs Supabase public client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Central admin dashboard used by /admin redirect.
VITE_ADMIN_DASHBOARD_URL=https://se7enfit-admin.onrender.com/admin

# Optional app download fallback links.
# Primary source is Super Admin settings.
VITE_APP_PLAY_STORE_URL=
VITE_APP_STORE_URL=
VITE_APP_APK_URL=

# Optional Google web login client. Must be a Web OAuth Client ID.
VITE_GOOGLE_WEB_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
